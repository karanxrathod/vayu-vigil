# Server Configuration
PORT=3001
JWT_SECRET=supersecrethackathonkey2026
NODE_ENV=development

# Database Configuration
# Default is SQLite for zero-config local run: sqlite://./cleanair.db
# For Docker Postgres + PostGIS: postgres://postgres:postgres@localhost:5432/cleanair_db
DATABASE_URL=sqlite://./cleanair.db

# Background Service Timers (in milliseconds)
SIMULATOR_INTERVAL_MS=10000
SCORING_INTERVAL_MS=30000

# AI Configuration
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
MOCK_MODE=true

# Alert Webhook
WEBHOOK_LOG_ONLY=true
